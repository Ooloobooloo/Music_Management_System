@model Music_Management_System.Models.Singer

@{
    ViewData["Title"] = "Add a Singer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero" style="margin-bottom: 1.75rem;">
    <div>
        <h1>Add a Singer</h1>
        <p>Fill in the details below to add a new singer</p>
    </div>
</div>

<div class="row">
    <div class="col-md-9">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Ludwig van Beethoven" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Biography" class="control-label">Biography</label>
                <textarea asp-for="Biography" class="form-control" id="editor"
                          placeholder="Write a short biography…"></textarea>
                <span asp-validation-for="Biography" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="imageFile" class="control-label">Photo</label>
                <input type="file" id="imageFile" name="imageFile"
                       class="form-control" accept="image/*" />
                <small class="form-text">JPG, PNG, or WEBP (optional)</small>
            </div>

            <div class="form-group mt-4 d-flex gap-3 align-items-center">
                <input type="submit" value="Save Singer" class="btn btn-primary px-4" />
                <a asp-action="Index" class="back-link">← Back to Singers</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'undo', 'redo']
            })
            .then(editor => console.log('CKEditor initialized', editor))
            .catch(error => console.error(error));
    </script>
    <partial name="_ValidationScriptsPartial" />
}
