@model Music_Management_System.Models.Composer

@{
    ViewData["Title"] = "Edit Composer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero" style="margin-bottom: 1.75rem;">
    <div>
        <h1>Edit Composer</h1>
        <p>Updating details for <strong>@Model.Name</strong></p>
    </div>
</div>

<div class="row">
    <div class="col-md-9">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Name" class="control-label">Full Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Biography" class="control-label">Biography</label>
                <textarea asp-for="Biography" class="form-control" id="editor"></textarea>
                <span asp-validation-for="Biography" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="imageFile" class="control-label">Photo</label>
                <input type="file" id="imageFile" name="imageFile"
                       class="form-control" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <small class="form-text">Current photo exists — upload a new one to replace it</small>
                }
                else
                {
                    <small class="form-text">JPG, PNG, or WEBP (optional)</small>
                }
            </div>

            <div class="form-group mt-4 d-flex gap-3 align-items-center">
                <input type="submit" value="Save Changes" class="btn btn-primary px-4" />
                <a asp-action="Details" asp-route-id="@Model.Id" class="back-link">← Back to Details</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'undo', 'redo']
            })
            .then(editor => console.log('CKEditor initialized', editor))
            .catch(error => console.error(error));
    </script>
    <partial name="_ValidationScriptsPartial" />
}
