@model Music_Management_System.Models.Composer

@{
    ViewData["Title"] = "Composer Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero" style="margin-bottom: 1.75rem;">
    <div>
        <h1>@Model.Name</h1>
        <p>Composer profile</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-primary">← Composers</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card p-0 overflow-hidden">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     class="img-fluid w-100" style="object-fit: cover; max-height: 280px;">
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center"
                     style="height: 220px; background: #e8d8c4; font-size: 4rem; opacity: .5;">
                    🎼
                </div>
            }
        </div>
    </div>

    <div class="col-md-8">
        @if (!string.IsNullOrEmpty(Model.Biography))
        {
            <div class="card p-4">
                <h5 class="card-title mb-3">Biography</h5>
                <div class="card-text" style="line-height: 1.8;">
                    @Html.Raw(Model.Biography)
                </div>
            </div>
        }
    </div>
</div>
