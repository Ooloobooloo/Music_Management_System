@model Music_Management_System.Models.Song

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'undo', 'redo']
            })
            .then(editor => {
                console.log('Editor was initialized', editor);
            })
            .catch(error => {
                console.error(error);
            });
    </script>
    <style>
        .ck-editor__editable {
            min-height: 200px;
            min-width: 100%; 
            max-width: 100%;
        }
    </style>
    <partial name="_ValidationScriptsPartial" />
}

<h1>Create</h1>

<h4>Song</h4>
<hr />
<div class="row">
    <div class="col-md-9">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Title" class="control-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Lyrics" class="control-label"></label>
                <textarea asp-for="Lyrics" class="form-control" id="editor"></textarea>
                <span asp-validation-for="Lyrics" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label for="thumbnailFile" class="control-label">Thumbnail (Image)</label>
                <input type="file" id="thumbnailFile" name="thumbnailFile" class="form-control" accept="image/*" />
                <small class="form-text text-muted">Select an image file to upload (optional)</small>
            </div>
            <div class="form-group">
                <label for="mp3File" class="control-label">MP3 File</label>
                <input type="file" id="mp3File" name="mp3File" class="form-control" accept="audio/mpeg,.mp3" />
                <small class="form-text text-muted">Select an MP3 file to upload (optional)</small>
            </div>
            <div class="form-group">
                <label asp-for="ReleaseDate" class="control-label"></label>
                <input asp-for="ReleaseDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SingerId" class="control-label"></label>
                <select asp-for="SingerId" class="form-control" asp-items="ViewBag.SingerId"></select>
            </div>
            <div class="form-group">
                <label asp-for="ComposerId" class="control-label"></label>
                <select asp-for="ComposerId" class="form-control" asp-items="ViewBag.ComposerId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>