@model IEnumerable<Music_Management_System.Models.Song>

@{
    ViewData["Title"] = "Song Library";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero">
    <div>
        <h1>Song Library</h1>
        <p>Browse, listen, and manage your music collection</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Add New Song</a>
</div>

<!-- Search Bar -->
<div class="row mb-4">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" 
                   name="searchTerm" 
                   value="@ViewBag.SearchTerm"
                   class="form-control" 
                   placeholder="Search by song title, singer, or composer..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <h4>No songs found</h4>
        <p>Try a different search term or add a new song.</p>
        <a asp-action="Create" class="btn btn-primary">+ Add New Song</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="row g-0">
                        <div class="col-4">
                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                            {
                                <img src="@item.ThumbnailUrl"
                                     class="img-fluid h-100 rounded-start"
                                     alt="@item.Title"
                                     style="object-fit: cover; min-height: 160px;">
                            }
                            else
                            {
                                <div class="bg-secondary d-flex align-items-center justify-content-center h-100"
                                     style="min-height: 160px; border-radius: 14px 0 0 14px;">
                                    <span style="font-size: 2.5rem; opacity: 0.5;">🎵</span>
                                </div>
                            }
                        </div>
                        <div class="col-8">
                            <div class="card-body d-flex flex-column h-100 py-3">
                                <h5 class="card-title">@item.Title</h5>

                                <p class="card-text mb-1">
                                    <strong>Singer:</strong> @item.Singer?.Name
                                </p>
                                <p class="card-text mb-1">
                                    <strong>Composer:</strong> @item.Composer?.Name
                                </p>
                                <p class="card-text mb-2">
                                    <strong>Released:</strong> @item.ReleaseDate.ToString("MMM dd, yyyy")
                                </p>

                                @if (!string.IsNullOrEmpty(item.MP3Url))
                                {
                                    <audio controls class="mt-auto mb-2 w-100">
                                        <source src="@item.MP3Url" type="audio/mpeg">
                                        Your browser does not support the audio element.
                                    </audio>
                                }

                                <div class="btn-group mt-auto" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <p class="text-muted">
            Showing @Model.Count() songs 
            @if (ViewBag.TotalItems != null)
            {
                <span>(Total: @ViewBag.TotalItems)</span>
            }
        </p>

        @if (ViewBag.TotalPages > 1)
        {
            <nav>
                <ul class="pagination">
                    <!-- Previous -->
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" 
                           asp-action="Index" 
                           asp-route-page="@(ViewBag.CurrentPage - 1)"
                           asp-route-searchTerm="@ViewBag.SearchTerm">Previous</a>
                    </li>

                    <!-- Page Numbers -->
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" 
                               asp-action="Index" 
                               asp-route-page="@i"
                               asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
                        </li>
                    }

                    <!-- Next -->
                    <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" 
                           asp-action="Index" 
                           asp-route-page="@(ViewBag.CurrentPage + 1)"
                           asp-route-searchTerm="@ViewBag.SearchTerm">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
}